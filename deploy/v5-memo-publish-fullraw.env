PYTHONPATH=/opt/v5-memo/src
RESEARKA_FULLRAW_SEARCH_URL=http://127.0.0.1:9935/search
V5_MEMO_FULL_RAW_CORPUS_SEARCH_URL=http://127.0.0.1:9935/search
RESEARKA_FULLRAW_INDEX_HOST=127.0.0.1
RESEARKA_FULLRAW_INDEX_PORT=9935
V5_MEMO_FULL_RAW_INDEX_HOST=127.0.0.1
V5_MEMO_FULL_RAW_INDEX_PORT=9935

RESEARKA_FULLRAW_SHARD_DIR=/var/lib/v5-memo/v5-publish-fullraw-fts-remote
RESEARKA_FULLRAW_SHARD_CATALOG_PATH=/var/lib/v5-memo/v5-isolated-fullraw-shard-catalog.json
RESEARKA_FULLRAW_SWEEP_CACHE_DIR=/var/lib/v5-memo/v5-publish-sweep-cache
RESEARKA_FULLRAW_SHARD_LOCAL_CACHE_DIR=/var/lib/v5-memo/v5-publish-shard-cache
# Dynamic eviction preserves 42 GiB before the mount's separate 1 GiB VFS cap.
RESEARKA_FULLRAW_SHARD_LOCAL_CACHE_MAX_BYTES=auto
RESEARKA_FULLRAW_SHARD_LOCAL_CACHE_MIN_FREE_GB=42

RESEARKA_FULLRAW_FAST_HEALTH=0
RESEARKA_FULLRAW_SEARCH_ISOLATED=1
RESEARKA_FULLRAW_SEARCH_WORKERS=1
RESEARKA_FULLRAW_SHARD_MANIFEST_STATS=1
RESEARKA_FULLRAW_MIN_SHARDS_SEARCHED=1525
RESEARKA_FULLRAW_MIN_SOURCES_SEARCHED=5
RESEARKA_FULLRAW_REQUIRE_COMPLETE_SEARCH=1
RESEARKA_FULLRAW_SWEEP_REQUIRE_COMPLETE=1
RESEARKA_FULLRAW_ASYNC_SWEEP=1
RESEARKA_FULLRAW_SWEEP_SHARD_LIMIT=1525
RESEARKA_FULLRAW_SWEEP_PASS_SHARD_LIMIT=12
RESEARKA_FULLRAW_SWEEP_NO_HIT_STOP_SHARDS=128
RESEARKA_FULLRAW_SWEEP_MAX_PASSES=5000
RESEARKA_FULLRAW_SWEEP_WORKERS=auto
RESEARKA_FULLRAW_SWEEP_MAX_INFLIGHT=auto
RESEARKA_FULLRAW_SWEEP_PRIORITY_BURST=0
RESEARKA_FULLRAW_SWEEP_MAX_QUEUE=4
RESEARKA_FULLRAW_SWEEP_TTL_SECONDS=604800
RESEARKA_FULLRAW_SWEEP_TIMEOUT_SECONDS=900
RESEARKA_FULLRAW_SWEEP_SHARD_TIMEOUT_SECONDS=180
RESEARKA_FULLRAW_SWEEP_WORKER_CACHE_BYTES=4294967296
RESEARKA_FULLRAW_MAX_VARIANTS=1
RESEARKA_FULLRAW_DOI_ABSTRACT_BACKFILL_LIMIT=16
