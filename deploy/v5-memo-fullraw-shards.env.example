# Storage Box-backed sharded fullraw index configuration.
#
# Do not point V5_MEMO_FULL_RAW_INDEX_PATH directly at a Storage Box mount for a
# live monolithic SQLite FTS database. Build local shards, upload finished shard
# files to Storage Box, then search local cached shards.

V5_MEMO_FULL_RAW_SHARD_REMOTE=sb:researka-database/index/v5/fullraw-fts
V5_MEMO_FULL_RAW_SHARD_CACHE=/var/cache/v5-memo/fullraw-shards
V5_MEMO_FULL_RAW_SHARD_CACHE_MAX_GB=60
V5_MEMO_FULL_RAW_SHARD_BUILD_DIR=/var/lib/v5-memo/shard-build
V5_MEMO_FULL_RAW_SHARD_MANIFEST=/var/lib/v5-memo/fullraw_shard_manifest.json
V5_MEMO_FULL_RAW_SHARDS=8
V5_MEMO_FULL_RAW_SHARD_WORKERS=8
V5_MEMO_FULL_RAW_SHARD_BATCH_FILES=16

# Search-service gate for final 5TB agent-search mode: narrow cached sweeps
# return 422 instead of usable hits. Keep these aligned with the mounted shard
# count reported by /health.
V5_MEMO_FULL_RAW_INDEX_PORT=9903
V5_MEMO_FULL_RAW_MIN_SHARDS_SEARCHED=1525
V5_MEMO_FULL_RAW_MIN_SOURCES_SEARCHED=5
V5_MEMO_FULL_RAW_REQUIRE_COMPLETE_SEARCH=1
V5_MEMO_FULL_RAW_SWEEP_REQUIRE_COMPLETE=1
V5_MEMO_FULL_RAW_SEARCH_ISOLATED=1
V5_MEMO_FULL_RAW_ASYNC_SWEEP=1
V5_MEMO_FULL_RAW_SWEEP_SHARD_LIMIT=1525
V5_MEMO_FULL_RAW_SWEEP_PASS_SHARD_LIMIT=8
V5_MEMO_FULL_RAW_SWEEP_MAX_PASSES=5000
V5_MEMO_FULL_RAW_SWEEP_WORKERS=8
V5_MEMO_FULL_RAW_SWEEP_MAX_INFLIGHT=2
V5_MEMO_FULL_RAW_SWEEP_TTL_SECONDS=604800
V5_MEMO_FULL_RAW_FOREGROUND_SWEEP_WAIT_SECONDS=900
V5_MEMO_FULL_RAW_SWEEP_TIMEOUT_SECONDS=3600
V5_MEMO_FULL_RAW_SWEEP_SHARD_TIMEOUT_SECONDS=90
V5_MEMO_FULL_RAW_SHARD_LOCAL_CACHE_DIR=
V5_MEMO_FULL_RAW_SHARD_LOCAL_CACHE_MAX_BYTES=
V5_MEMO_FULL_RAW_SHARD_CATALOG_PATH=/mnt/HC_Volume_106011525/v5-memo/fullraw-shard-catalog.json
V5_MEMO_FULL_RAW_SHARD_CATALOG_TTL_SECONDS=86400

# Memo/publish gate: fullraw/smart CLI runs inherit the two values above unless
# these memo-specific overrides are set.
# V5_MEMO_MEMO_MIN_SHARDS_SEARCHED=1525
# V5_MEMO_MEMO_MIN_SOURCES_SEARCHED=5
V5_MEMO_MEMO_MIN_SEARCH_PASSES=2
