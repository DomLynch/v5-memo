# Storage Box-backed sharded fullraw index configuration.
#
# Do not point RESEARKA_FULLRAW_INDEX_PATH directly at a Storage Box mount for a
# live monolithic SQLite FTS database. Build local shards, upload finished shard
# files to Storage Box, then search local cached shards.

RESEARKA_FULLRAW_SHARD_REMOTE=sb:researka-database/index/v5/fullraw-fts
RESEARKA_FULLRAW_SHARD_CACHE=/var/cache/v5-memo/fullraw-shards
RESEARKA_FULLRAW_SHARD_CACHE_MAX_GB=60
RESEARKA_FULLRAW_SHARD_BUILD_DIR=/var/lib/v5-memo/shard-build
RESEARKA_FULLRAW_SHARD_MANIFEST=/var/lib/v5-memo/fullraw_shard_manifest.json
RESEARKA_FULLRAW_SHARDS=8
RESEARKA_FULLRAW_SHARD_WORKERS=8
RESEARKA_FULLRAW_SHARD_BATCH_FILES=16
RESEARKA_FULLRAW_INDEX_PATH=/var/lib/v5-memo/index/fullraw_index.sqlite
RESEARKA_FULLRAW_SHARD_DIR=/var/lib/v5-memo/fullraw-fts-remote

# Search-service gate for final 5TB agent-search mode: narrow cached sweeps
# return 422 instead of usable hits. Keep these aligned with the mounted shard
# count reported by /health.
RESEARKA_FULLRAW_INDEX_PORT=9903
RESEARKA_FULLRAW_MIN_SHARDS_SEARCHED=1525
RESEARKA_FULLRAW_MIN_SOURCES_SEARCHED=5
RESEARKA_FULLRAW_REQUIRE_COMPLETE_SEARCH=1
RESEARKA_FULLRAW_SWEEP_REQUIRE_COMPLETE=1
RESEARKA_FULLRAW_SEARCH_ISOLATED=0
RESEARKA_FULLRAW_ASYNC_SWEEP=1
RESEARKA_FULLRAW_SWEEP_SHARD_LIMIT=1525
RESEARKA_FULLRAW_SWEEP_PASS_SHARD_LIMIT=32
RESEARKA_FULLRAW_SEARCH_PREFIX_SHARDS=128
RESEARKA_FULLRAW_SWEEP_MAX_PASSES=5000
RESEARKA_FULLRAW_SWEEP_WORKERS=8
RESEARKA_FULLRAW_SWEEP_MAX_INFLIGHT=1
RESEARKA_FULLRAW_SWEEP_PRIORITY_BURST=0
RESEARKA_FULLRAW_SWEEP_MAX_QUEUE=16
RESEARKA_FULLRAW_SWEEP_TTL_SECONDS=604800
RESEARKA_FULLRAW_SWEEP_CACHE_DIR=/var/lib/v5-memo/fullraw-sweep-cache
RESEARKA_FULLRAW_FOREGROUND_SWEEP_WAIT_SECONDS=900
RESEARKA_FULLRAW_SWEEP_TIMEOUT_SECONDS=120
RESEARKA_FULLRAW_SWEEP_SHARD_TIMEOUT_SECONDS=20
RESEARKA_FULLRAW_SHARD_LOCAL_CACHE_DIR=/mnt/HC_Volume_106011525/v5-memo/fullraw-shard-cache-remote
RESEARKA_FULLRAW_SHARD_LOCAL_CACHE_MAX_BYTES=auto
RESEARKA_FULLRAW_SHARD_CATALOG_PATH=/var/lib/v5-memo/fullraw-shard-catalog.json
RESEARKA_FULLRAW_SHARD_CATALOG_TTL_SECONDS=86400

# Memo/publish gate: fullraw/smart CLI runs inherit the two values above unless
# these memo-specific overrides are set.
# V5_MEMO_MEMO_MIN_SHARDS_SEARCHED=1525
# V5_MEMO_MEMO_MIN_SOURCES_SEARCHED=5
V5_MEMO_MEMO_MIN_SEARCH_PASSES=2
