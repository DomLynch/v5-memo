# V5-only fullraw lane overrides.
#
# Load this after /etc/v5-memo/env. Keep V5 isolated from the shared 9903/9917
# fullraw mount so V5 can tune rclone/cache behavior without touching other
# agents.

RESEARKA_FULLRAW_SEARCH_URL=http://127.0.0.1:9915/search
V5_MEMO_FULL_RAW_CORPUS_SEARCH_URL=http://127.0.0.1:9915/search
RESEARKA_FULLRAW_INDEX_HOST=127.0.0.1
RESEARKA_FULLRAW_INDEX_PORT=9915
V5_MEMO_FULL_RAW_INDEX_HOST=127.0.0.1
V5_MEMO_FULL_RAW_INDEX_PORT=9915

RESEARKA_FULLRAW_SHARD_DIR=/var/lib/v5-memo/v5-isolated-fullraw-fts-remote
RESEARKA_FULLRAW_SHARD_CATALOG_PATH=/var/lib/v5-memo/v5-isolated-fullraw-shard-catalog.json
RESEARKA_FULLRAW_SWEEP_CACHE_DIR=/var/lib/v5-memo/v5-fullraw-sweep-cache
RESEARKA_FULLRAW_SHARD_LOCAL_CACHE_DIR=/var/lib/v5-memo/v5-shard-cache-5tb
RESEARKA_FULLRAW_SHARD_LOCAL_CACHE_MAX_BYTES=auto
RESEARKA_FULLRAW_SHARD_LOCAL_CACHE_MIN_FREE_GB=20
RESEARKA_FULLRAW_SWEEP_WORKER_CACHE_GB=1

RESEARKA_FULLRAW_FAST_HEALTH=1
RESEARKA_FULLRAW_SEARCH_ISOLATED=1
RESEARKA_FULLRAW_MIN_SHARDS_SEARCHED=1525
RESEARKA_FULLRAW_MIN_SOURCES_SEARCHED=5
RESEARKA_FULLRAW_REQUIRE_COMPLETE_SEARCH=1
RESEARKA_FULLRAW_SWEEP_REQUIRE_COMPLETE=1
RESEARKA_FULLRAW_ASYNC_SWEEP=1
RESEARKA_FULLRAW_SWEEP_SHARD_LIMIT=1525
RESEARKA_FULLRAW_SWEEP_PASS_SHARD_LIMIT=32
RESEARKA_FULLRAW_SWEEP_MAX_PASSES=5000
RESEARKA_FULLRAW_SWEEP_WORKERS=auto
RESEARKA_FULLRAW_SWEEP_MAX_INFLIGHT=2
RESEARKA_FULLRAW_SWEEP_PRIORITY_BURST=0
RESEARKA_FULLRAW_SWEEP_MAX_QUEUE=4
RESEARKA_FULLRAW_SWEEP_TTL_SECONDS=604800
RESEARKA_FULLRAW_SWEEP_TIMEOUT_SECONDS=120
RESEARKA_FULLRAW_SWEEP_SHARD_TIMEOUT_SECONDS=20
RESEARKA_FULLRAW_MAX_VARIANTS=1
