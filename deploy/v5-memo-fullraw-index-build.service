[Unit]
Description=V5 Memo fullraw FTS index builder
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/v5-memo
EnvironmentFile=/etc/v5-memo/env
Environment=PYTHONPATH=/opt/v5-memo/src
ExecStart=/usr/bin/python3 -m v5_memo.fullraw_index build --commit-interval 5000
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
