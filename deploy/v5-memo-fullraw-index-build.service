[Unit]
Description=V5 Memo fullraw FTS index builder
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/v5-memo
EnvironmentFile=/etc/v5-memo/env
Environment=PYTHONPATH=/opt/v5-memo/src
Environment=V5_MEMO_FULL_RAW_INDEX_MIN_FREE_GB=60
ExecStart=/usr/bin/python3 -m v5_memo.fullraw_index build --commit-interval 5000
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
