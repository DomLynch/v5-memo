[Unit]
Description=V5 Memo portfolio publisher
Wants=network-online.target v5-memo-isolated-fullraw-search.service
After=network-online.target v5-memo-isolated-fullraw-search.service

[Service]
TimeoutStartSec=150min
Type=oneshot
WorkingDirectory=/opt/v5-memo
EnvironmentFile=/etc/v5-memo/env
EnvironmentFile=/etc/v5-memo/isolated-fullraw.env
EnvironmentFile=/etc/v5-memo/researka-submit.env
Environment=PYTHONPATH=/opt/v5-memo/src
Environment=V5_MEMO_PORTFOLIO_MAX_LEADS=12
Environment=V5_MEMO_PORTFOLIO_LEAD_TIMEOUT_SECONDS=600
ExecStart=/bin/bash -lc 'run_dir=/var/lib/v5-memo/portfolio-runs/$(date -u +%%Y%%m%%dT%%H%%M%%SZ); mkdir -p "$run_dir"; exec /usr/bin/python3 scripts/v5_publish_portfolio.py --submit --lead-file /etc/v5-memo/v5-portfolio-leads.txt --output-dir "$run_dir" --state-path /var/lib/v5-memo/portfolio-runs/state.json --auto-discover-leads --min-open-leads 40 --discover-count 20 --blocked-retry-hours 24 --max-leads "${V5_MEMO_PORTFOLIO_MAX_LEADS:-12}" --lead-timeout-seconds "${V5_MEMO_PORTFOLIO_LEAD_TIMEOUT_SECONDS:-600}" --decision-wait-seconds 180 --decision-poll-seconds 5 --submit-wait-seconds 30'
